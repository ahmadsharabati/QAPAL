# Dot files / hidden dirs
.*
!.gitignore

# Environment & secrets
toolbox_creds.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/
plans/

# Node / Extension
node_modules/

# Data files (large / runtime-generated)
locators.json
reports/
:memory:          # TinyDB in-memory snapshot — never commit

# Old plan archives
plans_final_v*/
plans_verification/
